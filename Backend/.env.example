# Copy to .env and fill in values:
#   copy .env.example .env
#
# Local development: defaults below are fine (DEBUG=True).
# Production: set DEBUG=False and fill every value marked REQUIRED.

# --- Security (REQUIRED in production) ---
DEBUG=True
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=
# Your public site URL — auto-configures hosts, CORS, CSRF, and password-reset links
# Example: https://dopekit.co.ke
SITE_URL=
# Public URL of the React app (defaults to SITE_URL; set if API and frontend differ)
FRONTEND_URL=http://localhost:5173
# Optional extra domains (comma-separated). Platform hostnames (Render/Railway/etc.) are auto-detected.
ALLOWED_HOSTS=localhost,127.0.0.1
# Optional overrides — usually not needed if SITE_URL/FRONTEND_URL are set
# CORS_ALLOWED_ORIGINS=https://dopekit.co.ke,https://www.dopekit.co.ke
# CSRF_TRUSTED_ORIGINS=https://dopekit.co.ke,https://www.dopekit.co.ke
# Shared cookie domain when API and frontend are subdomains, e.g. .dopekit.co.ke
# COOKIE_DOMAIN=

# --- HTTP / HTTPS cookies ---
# Local HTTP (default for dev):
USE_HTTPS=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax

# Production HTTPS example (uncomment and adjust):
# USE_HTTPS=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SESSION_COOKIE_SAMESITE=Lax
# CSRF_COOKIE_SAMESITE=Lax

# Split frontend + API on different domains (HTTPS only):
# SESSION_COOKIE_SAMESITE=None
# CSRF_COOKIE_SAMESITE=None

# Optional cookie tuning
# SESSION_COOKIE_AGE=1209600
# SESSION_COOKIE_NAME=dopekit_session
# SESSION_SAVE_EVERY_REQUEST=False
# SESSION_EXPIRE_AT_BROWSER_CLOSE=False

# Set True only if your host does NOT terminate HTTPS before Django
SECURE_SSL_REDIRECT=False
ALLOW_TECHNICIAN_SELF_SIGNUP=True

# --- Salon ---
SALON_LOCATION=Dopekit Studio, Kikuyu Town
TIME_ZONE=Africa/Nairobi

# --- Database (PostgreSQL) ---
# Create the database first:  createdb nails_service
# Or use one URL from Render/Railway/Supabase:
# DATABASE_URL=postgresql://user:password@host:5432/nails_service
POSTGRES_DB=nails_service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# POSTGRES_SSLMODE=require
# Set USE_SQLITE=True only for quick local dev without PostgreSQL
# USE_SQLITE=False
# --- Notifications ---
BOOKING_NOTIFY_EMAIL=mungaimichael638@gmail.com
BOOKING_NOTIFY_PHONE=+254790331108

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=mungaimichael638@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password-here
DEFAULT_FROM_EMAIL=mungaimichael638@gmail.com

AT_USERNAME=sandbox
AT_API_KEY=your-africastalking-api-key-here
AT_SENDER_ID=

# --- Deploy (Gunicorn / Render / Railway / Nginx) ---
# Render: connect repo and use render.yaml (Backend + Frontend + Postgres)
# Railway: connect repo; uses railway.toml + Backend/nixpacks.toml
# VPS: deploy/nginx/dopekit.conf + deploy/systemd/dopekit.service + scripts/start.sh
# WEB_CONCURRENCY=2
# GUNICORN_THREADS=2
# GUNICORN_TIMEOUT=120
# Production example after deploy:
# SITE_URL=https://dopekit-api.onrender.com
# FRONTEND_URL=https://dopekit-web.onrender.com
# VITE_API_BASE (Frontend build) = https://dopekit-api.onrender.com
