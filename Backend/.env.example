# Copy to .env and fill in your credentials:
#   copy .env.example .env
#
# Quick start (Gmail only):
#   1. Enable 2-Step Verification on your Google account
#   2. Create an App Password: https://myaccount.google.com/apppasswords
#   3. Paste it as EMAIL_HOST_PASSWORD in .env
#   4. Run: python manage.py test_email

# Where booking alerts are sent
BOOKING_NOTIFY_EMAIL=mungaimichael638@gmail.com
BOOKING_NOTIFY_PHONE=+254790331108

# Gmail SMTP — use an App Password (not your normal Gmail password)
# https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=mungaimichael638@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password-here
DEFAULT_FROM_EMAIL=mungaimichael638@gmail.com

# Africa's Talking SMS — https://africastalking.com
# SANDBOX: SMS does NOT arrive on your real phone. Use "Launch Simulator"
# in the AT dashboard to view test messages (register +254790331108 there).
# PRODUCTION: Top up your account for real SMS to 0790331108.
AT_USERNAME=sandbox
AT_API_KEY=your-africastalking-api-key-here
AT_SENDER_ID=
